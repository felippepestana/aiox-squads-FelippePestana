# Caddyfile — Reverse proxy para AIOX Squads
#
# Instrucoes:
#   1. Substitua "seudominio.com.br" pelo seu dominio real
#   2. Copie para o VPS: sudo cp Caddyfile /etc/caddy/Caddyfile
#   3. Reload: sudo systemctl reload caddy
#   4. Caddy obtem certificado SSL automaticamente via Let's Encrypt
#
# Pre-requisito: DNS do dominio apontando para o IP do VPS

# ── Portal Web (React + Express) ─────────────────────────────────────────────
seudominio.com.br {
	reverse_proxy localhost:8787

	encode gzip zstd

	header {
		# Security headers
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	log {
		output file /var/log/caddy/web-access.log {
			roll_size 50MiB
			roll_keep 5
		}
	}
}

# ── Chatbot API ──────────────────────────────────────────────────────────────
chatbot.seudominio.com.br {
	reverse_proxy localhost:3000

	encode gzip zstd

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	log {
		output file /var/log/caddy/chatbot-access.log {
			roll_size 50MiB
			roll_keep 5
		}
	}
}
