# Supabase — obrigatório
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Necessário para uploads em buckets privados (nunca expor ao cliente)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# URL pública do app — usada nos links de WhatsApp, emails e QR codes
NEXT_PUBLIC_APP_URL=https://seu-dominio.netlify.app

# WhatsApp via Evolution API (opcional — sem isso, envios são ignorados silenciosamente)
# Setup: https://doc.evolution-api.com/v1/installation
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=legendarios
