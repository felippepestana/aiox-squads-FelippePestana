# Prometheus Alert Rules Template
# Generated by: @monitor-sentinel
# Principles: SLO-based, actionable, symptom-focused, runbook-linked

groups:
  - name: slo_alerts
    rules:
      # --- Availability SLO (burn rate) ---
      - alert: HighErrorBurnRate_Critical
        expr: |
          (
            sum(rate(http_requests_total{code=~"5.."}[5m]))
            /
            sum(rate(http_requests_total[5m]))
          ) > (14.4 * (1 - {{slo_target|0.999}}))
        for: 2m
        labels:
          severity: critical
          slo: availability
        annotations:
          summary: "High error burn rate — SLO at risk"
          description: "Error rate is burning through the error budget 14.4x faster than allowed. Current: {{ $value | humanizePercentage }}"
          runbook: "{{runbook_base_url}}/high-error-rate"

      - alert: HighErrorBurnRate_Warning
        expr: |
          (
            sum(rate(http_requests_total{code=~"5.."}[30m]))
            /
            sum(rate(http_requests_total[30m]))
          ) > (6 * (1 - {{slo_target|0.999}}))
        for: 15m
        labels:
          severity: warning
          slo: availability
        annotations:
          summary: "Elevated error burn rate"
          description: "Error rate is burning error budget 6x faster than allowed over 30m window."
          runbook: "{{runbook_base_url}}/elevated-error-rate"

      # --- Latency SLO ---
      - alert: HighLatency_Critical
        expr: |
          histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))
          > {{latency_p99_threshold|1.0}}
        for: 5m
        labels:
          severity: critical
          slo: latency
        annotations:
          summary: "P99 latency exceeds SLO threshold"
          description: "P99 latency is {{ $value }}s, threshold is {{latency_p99_threshold|1.0}}s"
          runbook: "{{runbook_base_url}}/high-latency"

  - name: golden_signals
    rules:
      # --- Saturation ---
      - alert: HighCPUUsage
        expr: (1 - avg(rate(node_cpu_seconds_total{mode="idle"}[5m]))) > 0.85
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "CPU usage above 85% for 10+ minutes"
          runbook: "{{runbook_base_url}}/high-cpu"

      - alert: HighMemoryUsage
        expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) > 0.85
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Memory usage above 85% for 10+ minutes"
          runbook: "{{runbook_base_url}}/high-memory"

      - alert: DiskSpaceLow
        expr: (1 - node_filesystem_avail_bytes / node_filesystem_size_bytes) > 0.90
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Disk usage above 90%"
          runbook: "{{runbook_base_url}}/disk-space"

  - name: container_alerts
    rules:
      - alert: ContainerRestarting
        expr: increase(kube_pod_container_status_restarts_total[1h]) > 3
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Container {{ $labels.container }} restarting frequently"
          runbook: "{{runbook_base_url}}/container-restart"

      - alert: PodNotReady
        expr: kube_pod_status_ready{condition="true"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Pod {{ $labels.pod }} not ready for 5+ minutes"
          runbook: "{{runbook_base_url}}/pod-not-ready"
