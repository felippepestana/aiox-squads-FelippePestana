# Multi-stage Node.js Dockerfile Template
# Generated by: @container-engineer
# Principles: multi-stage, non-root, minimal image, health checks

# --- Stage 1: Dependencies ---
FROM node:{{node_version|20}}-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --only=production && \
    cp -R node_modules /prod_modules && \
    npm ci

# --- Stage 2: Build ---
FROM node:{{node_version|20}}-alpine AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

# --- Stage 3: Production ---
FROM node:{{node_version|20}}-alpine AS production
LABEL maintainer="{{maintainer}}"
LABEL org.opencontainers.image.source="{{repo_url}}"

# Security: non-root user
RUN addgroup -g 1001 -S appgroup && \
    adduser -S appuser -u 1001 -G appgroup

WORKDIR /app

# Copy only production artifacts
COPY --from=deps /prod_modules ./node_modules
COPY --from=build /app/dist ./dist
COPY package.json ./

# Security: read-only filesystem where possible
RUN chown -R appuser:appgroup /app

USER appuser

EXPOSE {{port|3000}}

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:{{port|3000}}/health || exit 1

CMD ["node", "dist/index.js"]
