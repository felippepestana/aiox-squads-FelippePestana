# ── OBS WebSocket ─────────────────────────────────────────
# Host and port are pre-filled in Settings → OBS when these vars are set.
# The password is NEVER stored in env vars — enter it in the Settings UI each session.
OBS_WS_HOST=localhost
OBS_WS_PORT=4455

# Legacy (kept for backwards compat, prefer the vars above)
NEXT_PUBLIC_OBS_WS_URL=ws://localhost:4455

# Path to mic-mapping.yaml — resolved relative to operator-panel/ (this .env file).
MIC_MAPPING_PATH=../data/mic-mapping.yaml

# ── Supabase ──────────────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
# Without these, the panel runs in local-only mode (YAML + sessionStorage).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service role key — used by the F6 Python engine to insert switch logs.
# Do NOT expose this to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Google Meet API (optional) ────────────────────────────
# Required only if you want programmatic room creation via Meet REST API v2.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── F6 Engine metrics (optional) ──────────────────────────
# URL of the Prometheus /metrics endpoint exposed by the F6 auto-switch engine.
PROMETHEUS_ENDPOINT=http://localhost:9099/metrics

# ── Webhooks (optional) ───────────────────────────────────
WEBHOOK_URL=
WEBHOOK_SECRET=

# ── TouchOSC bridge (optional) ────────────────────────────
# Enable the OSC↔OBS bridge inside the Next.js process. When enabled, the
# panel listens for OSC messages on UDP and relays scene/audio/PiP commands
# to OBS WebSocket. See data/osc-mapping.yaml for the address protocol.
OSC_BRIDGE_ENABLED=false
# Bridge listen port (TouchOSC sends here)
OSC_PORT=9300
# Tablet IP address (TouchOSC listens for feedback here)
OSC_FEEDBACK_HOST=127.0.0.1
# Bridge sends OBS feedback to this port
OSC_FEEDBACK_PORT=9301

# Server-side OBS credentials used by the OSC bridge (the bridge needs its
# own connection because the browser session credentials live only in the
# operator's tab). Do NOT set NEXT_PUBLIC_*; this stays server-only.
OSC_OBS_PASSWORD=

# Path to osc-mapping.yaml — resolved relative to operator-panel/.
OSC_MAPPING_PATH=../data/osc-mapping.yaml
