# OBS WebSocket connection (obs-websocket v5).
# Configure in OBS: Tools -> WebSocket Server Settings.
NEXT_PUBLIC_OBS_WS_URL=ws://localhost:4455
NEXT_PUBLIC_OBS_WS_PASSWORD=change-me

# Path to mic-mapping.yaml (relative to repo root) — read at build time.
MIC_MAPPING_PATH=../data/mic-mapping.yaml
