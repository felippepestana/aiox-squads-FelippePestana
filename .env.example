# Exemplo para Docker Compose na raiz do repositório (docker-compose.web.yml).
# Copie para .env e preencha. Não commite .env.

ANTHROPIC_API_KEY=

# Opcional: protege a API do portal (a UI pede a chave no browser).
# WEB_PORTAL_API_KEY=

# Porta do portal no host (docker compose --profile web)
# WEB_PORT=8787

# Porta do chatbot no host (docker compose --profile chatbot)
# CHATBOT_PORT=3000

# Origens CORS permitidas (separadas por vírgula). Vazio = reflete o pedido (dev).
# CORS_ORIGIN=https://app.exemplo.com

# Confiança no proxy (X-Forwarded-*). 1 em produção atrás de Nginx/Traefik; 0 local puro.
# TRUST_PROXY=1

# Portal web: limites de pedidos (ver web/.env.example)
# RATE_LIMIT_ENABLED=
# RATE_LIMIT_MAX=
# RATE_LIMIT_HEAVY_MAX=
