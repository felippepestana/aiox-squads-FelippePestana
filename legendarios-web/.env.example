# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Ticket and GO
TICKET_AND_GO_API_KEY=your-ticketandgo-key
TICKET_AND_GO_API_URL=https://api.ticketandgo.com.br/v1
TICKET_AND_GO_WEBHOOK_SECRET=your-webhook-secret

# WhatsApp Business Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# Meta Ads API
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=act_your-account-id
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret

# Email — Resend
RESEND_API_KEY=re_...
EMAIL_FROM=eventos@legendarios.com.br

# Pagar.me (PIX)
PAGARME_API_KEY=ak_...
PAGARME_ENCRYPTION_KEY=ek_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=your-app-secret-32-chars-minimum
