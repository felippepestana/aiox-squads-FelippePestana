# Copie para .env na pasta web/ (não commite .env)
ANTHROPIC_API_KEY=

# Opcional: se definida, todas as rotas /api/* (exceto health e auth/status)
# exigem header X-Portal-Key ou Authorization: Bearer <valor>.
# A UI pede a chave uma vez e guarda em sessionStorage.
# WEB_PORTAL_API_KEY=

# Opcional: pasta de squads (padrão: ../squads em relação a web/)
# SQUADS_ROOT=C:\caminho\para\aiox-squads-FelippePestana\squads

# Porta da API (padrão 8787)
# PORT=8787

# CORS: lista separada por vírgulas, ou vazio para permitir qualquer origem (útil só em dev)
# CORS_ORIGIN=http://127.0.0.1:5173

# Trust proxy (1 = atrás de reverse proxy em produção)
# TRUST_PROXY=0

# Rate limit (por IP). Desative com RATE_LIMIT_ENABLED=0
# RATE_LIMIT_MAX=200
# RATE_LIMIT_HEAVY_MAX=30
# RATE_LIMIT_ENABLED=1
