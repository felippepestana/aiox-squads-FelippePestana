# .env.production.example — Template para deploy em VPS (Hostinger)
# Copie para .env no VPS: cp .env.production.example .env
# NUNCA commite o .env com valores reais.

# ── Obrigatório ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-SUBSTITUA_PELA_SUA_CHAVE

# ── Portal Web ───────────────────────────────────────────────────────────────
# Protege a API do portal (recomendado em produção)
WEB_PORTAL_API_KEY=gere-uma-chave-segura-aqui

# Portas (mapeadas internamente pelo Docker)
WEB_PORT=8787
CHATBOT_PORT=3000

# CORS: domínios permitidos (separar por vírgula)
CORS_ORIGIN=https://seudominio.com.br,https://chatbot.seudominio.com.br

# Proxy: 1 quando atrás de Caddy/Nginx
TRUST_PROXY=1

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=1
RATE_LIMIT_MAX=200
RATE_LIMIT_HEAVY_MAX=30

# ── Monitoramento ────────────────────────────────────────────────────────────
# Sentry DSN (servidor Node) — obtenha em sentry.io
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# ── Node.js ──────────────────────────────────────────────────────────────────
NODE_ENV=production
